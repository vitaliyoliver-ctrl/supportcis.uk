# ── Frontend env (Vite) ──────────────────────────────────────────────────────
# Скопируйте в .env и заполните значениями СВОЕГО окружения.
# Никаких значений конкретного проекта в репозитории быть не должно.

# Supabase — только для страницы «Перерывы» (Realtime + REST).
# По умолчанию используется общий Supabase-проект компании (зашит как fallback),
# поэтому перерывы работают и без .env. Задавай эти переменные, только если
# хочешь СВОЙ проект Supabase (нужна таблица `bookings` + Realtime).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL воркера (нужен, только если фронт и API на разных origin).
# При деплое одним воркером (фронт + /api в одном месте) можно не задавать.
VITE_WORKER_URL=

# Dev only: "1" — поднять mock-API плагин (без реального воркера).
VITE_MOCK_API=
