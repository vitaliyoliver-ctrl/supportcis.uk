# Скопируйте в .env и заполните. Используется docker-compose.yml.

# ── Postgres (хранилище: сессии, роли, профили, график, продажи, оргструктура) ─
POSTGRES_USER=supportcis
POSTGRES_PASSWORD=change_me_to_a_strong_secret
POSTGRES_DB=supportcis

# ── Приложение ────────────────────────────────────────────────────────────────
APP_PORT=8787                              # порт на хосте (за ним — ваш reverse-proxy/TLS)
SITE=https://portal.example.com            # публичный адрес портала (CORS + ссылки)
OWNER_EMAIL=owner@velvix.org               # первый вход с этого адреса → роль TL (bootstrap)
ALLOWED_DOMAINS=velvix.org,gameup.club     # домены корпоративной почты, которым разрешён вход

# ── Resend (письма с одноразовыми кодами входа) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx                 # API-ключ Resend
RESEND_FROM=SupportCIS <noreply@your_verified_domain>   # домен должен быть верифицирован в Resend

# ── Telegram-бот для заявок на обмен смен (опционально) ────────────────────────
TG_BOT_TOKEN=                              # токен бота
TG_WEBHOOK_SECRET=                         # секрет вебхука (должен совпасть с setWebhook)
TG_CHAT_ID=                                # чат для заявок

# ── Supabase (страница «Перерывы») ─────────────────────────────────────────────
# НЕ задаётся здесь: это переменные ФРОНТА (VITE_*), вшиваются при сборке. Общий
# проект компании уже зашит как fallback — перерывы работают из коробки. Свой
# проект — только через build-args (см. DEPLOY.md), а не через этот .env.
